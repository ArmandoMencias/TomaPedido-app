<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#F5F5F5">

    <TextView
        android:id="@+id/tvTituloCuenta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cuenta de: "
        android:textSize="26sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCuentaDetalle"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/tvTituloCuenta"
        app:layout_constraintBottom_toTopOf="@id/tvTotalCuenta" />

    <TextView
        android:id="@+id/tvTotalCuenta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Total: $0.00"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#4CAF50"
        android:layout_marginBottom="24dp"
        app:layout_constraintBottom_toTopOf="@id/btnAgregarMas"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnAgregarMas"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="+ AGREGAR PRODUCTOS"
        android:backgroundTint="#2196F3"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/btnCerrarCuenta" />

    <Button
        android:id="@+id/btnCerrarCuenta"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="CERRAR CUENTA Y COBRAR"
        android:backgroundTint="#F44336"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>