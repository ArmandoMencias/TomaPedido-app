<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#F0F2F5"> <!-- Fondo gris muy claro para resaltar las tarjetas -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bienvenido"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="40dp"/>

    <!-- CARD MESERO -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardMesero"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:layout_marginBottom="24dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_mesero"
            android:padding="16dp">

            <ImageView
                android:id="@+id/iconMesero"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/iconMesero"
                android:layout_centerVertical="true"
                android:layout_marginStart="20dp"
                android:text="MODO\nMESERO"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <!-- CARD COCINA -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardCocina"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_cocina"
            android:padding="16dp">

            <!-- Icono que representa cocina (cubiertos/restaurante) -->
            <ImageView
                android:id="@+id/iconCocina"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_menu_gallery"
                app:tint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/iconCocina"
                android:layout_centerVertical="true"
                android:layout_marginStart="20dp"
                android:text="MODO\nCOCINA"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>