<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#F0F2F5">

    <!-- Cabecera: Título del Menú -->
    <TextView
        android:id="@+id/tvTituloMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MENÚ"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#333333"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Card para la selección de Comensal/Mesa -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardSelector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvTituloMenu">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Asignar pedido a:"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1565C0"
                android:textAllCaps="true"
                android:layout_marginBottom="4dp"/>

            <Spinner
                android:id="@+id/spinnerComensales"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@android:drawable/btn_dropdown"
                android:spinnerMode="dropdown" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Lista de Platillos (RecyclerView) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMenu"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintTop_toBottomOf="@id/cardSelector"
        app:layout_constraintBottom_toTopOf="@id/btnEnviarCocina"
        tools:listitem="@android:layout/simple_list_item_checked" />

    <!-- Botón Enviar a Cocina (Estilo Material) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnEnviarCocina"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="ENVIAR PEDIDO A COCINA"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="12dp"
        app:icon="@android:drawable/ic_menu_send"
        app:iconGravity="textStart"
        android:backgroundTint="#4CAF50"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>